<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_recent_surface"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="54dp"
        android:layout_height="54dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/recentImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bg_cover_missing"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.SpotifyKeeper.MediumImage" />

        <TextView
            android:id="@+id/recentFallbackText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#FAFEFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/recentTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recentSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#C8D4E8"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/recentAgoText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="agora"
        android:textColor="#AFC1DE"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
