<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_metric_surface"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/statValueText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0"
            android:textColor="#62E38F"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statDeltaText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-0%"
            android:textColor="#F06A6A"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/statLabelText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="metrica"
        android:textColor="#F2F6FB"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
